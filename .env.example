# ======================================
# 环境变量模板（复制为 .env 并填入真实值）
# ======================================

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxxxxx

# LangSmith 追踪（容器内可通过环境变量开关）
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_xxxx
LANGSMITH_PROJECT="Data Analysis Deep Agent"
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # 可选

# PostgreSQL（开发环境用，容器内会被覆盖）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/analysis

# Modal 凭证（容器化必须，否则无法调用沙箱）
MODAL_TOKEN_ID=xxx
MODAL_TOKEN_SECRET=xxx

# 环境标识（development / container），通常由 docker-compose 设置
# ENVIRONMENT=development